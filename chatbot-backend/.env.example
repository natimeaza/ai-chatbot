# .env.example – copy to .env and fill in real values

# Server
PORT=8000
HOST=0.0.0.0

# LLM – choose ONE provider and fill only its key
OPENAI_API_KEY=sk-xxx-your-key-here
# GROQ_API_KEY=gsk_xxx
# or leave empty if using local Ollama / other

# For later: database (SQLite for now – no password needed)
DATABASE_URL=sqlite+aiosqlite:///./chatbot.db

# Optional: secret for JWT if you add auth later
SECRET_KEY=your-super-secret-change-this-1234567890